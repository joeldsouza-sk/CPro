  .nyt-source a { color: var(--light-blue); text-decoration: none; border-bottom: 0.5px solid var(--light-blue); }

  /* ── CTA ── */
  .cta-wrap { padding: 0 40px 40px; background: var(--bg); }
  .cta-block { border-radius: 8px; background: var(--navy); padding: 38px 40px; display: flex; align-items: center; justify-content: space-between; gap: 28px; position: relative; overflow: hidden; box-shadow: 0 4px 20px rgba(26,82,145,0.2); }
