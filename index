  .logo-name span { color: var(--light-blue); }

  /* ── HERO ── */
  .hero {
    padding: 48px 40px 40px;
    background: var(--white);
    border-bottom: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }
  .hero-accent { position: absolute; top: 0; left: 0; width: 5px; height: 100%; background: linear-gradient(180deg, var(--navy) 0%, var(--crimson) 100%); }
  .hero-bg { position: absolute; inset: 0; background: radial-gradient(ellipse at 90% 50%, rgba(107,143,212,0.07) 0%, transparent 60%); pointer-events: none; }
  .hero-eyebrow { font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(--navy); margin-bottom: 14px; }
