  .footer-sep { color: rgba(255,255,255,0.25); font-size: 16px; }

  /* ── TABLET (≤768px): stats 2-col, cards stay 2-col ── */
  @media (max-width: 768px) {
    .hero { padding: 36px 24px 32px; }
    .section, .nyt-block { padding: 30px 24px; }
    .cta-wrap { padding: 0 24px 32px; }
    .divider { margin: 0 24px; }

    /* Stats: 2-col on tablet */
    .stats-row { grid-template-columns: repeat(2, 1fr); }
    .stat-cell { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.1); }
    .stat-cell:nth-child(odd) { border-right: 1px solid rgba(255,255,255,0.1); }
    .stat-cell:nth-last-child(-n+2) { border-bottom: none; }

    /* Cards stay 2-col on tablet */
    .win-grid, .pref-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }

    /* NYT stays 3-col on tablet */
    .nyt-stats-row { grid-template-columns: repeat(3, 1fr); }

    /* CTA stacks on tablet */
    .cta-block { flex-direction: column; align-items: flex-start; padding: 28px 24px; gap: 20px; }
    .cta-right { width: 100%; }
    .cta-btn { width: 100%; text-align: center; display: block; }
  }

  /* ── MOBILE (≤480px): cards go 1-col, NYT stacks ── */
  @media (max-width: 480px) {
    .hero-headline { font-size: 22px; }
    .hero-sub { font-size: 13.5px; }
    .stat-num { font-size: 26px; }
    .section-headline { font-size: 17px; }

    /* Cards: 1-col on mobile */
    .win-grid, .pref-grid { grid-template-columns: 1fr; }

    /* NYT: stacks on mobile */
    .nyt-stats-row { grid-template-columns: 1fr; }
    .nyt-stat-cell { border-right: none; border-bottom: 1px solid var(--border); }
    .nyt-stat-cell:last-child { border-bottom: none; }

    .footer-bar { flex-direction: column; gap: 6px; }
    .footer-sep { display: none; }
  }
</style>

