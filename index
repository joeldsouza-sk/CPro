  .hero-sub { font-size: clamp(14px, 2vw, 15px); color: var(--text-secondary); line-height: 1.8; font-weight: 400; }

  /* ── STATS: 4-col desktop, 2-col tablet+mobile ── */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }
  .stat-cell { background: var(--navy); padding: 22px 12px; text-align: center; border-right: 1px solid rgba(255,255,255,0.1); }
  .stat-cell:last-child { border-right: none; }
  .stat-num { font-family: 'Montserrat', sans-serif; font-size: clamp(22px, 3.5vw, 30px); font-weight: 800; color: var(--white); line-height: 1; margin-bottom: 6px; }
  .stat-label { font-size: clamp(10px, 1.5vw, 11px); color: rgba(255,255,255,0.6); font-weight: 400; line-height: 1.4; }

  /* ── SECTIONS ── */
  .section { padding: 40px; background: var(--bg); }
  .section-alt { background: var(--white); }
  .section-eyebrow { font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(--crimson); margin-bottom: 6px; }
