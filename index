  .cta-headline { font-family: 'Montserrat', sans-serif; font-size: clamp(18px, 2.5vw, 22px); font-weight: 800; color: var(--white); margin-bottom: 10px; line-height: 1.3; }
  .cta-sub { font-size: clamp(13px, 1.8vw, 14px); color: rgba(255,255,255,0.65); font-weight: 400; line-height: 1.7; max-width: 380px; }
  .cta-right { flex-shrink: 0; }
  .cta-btn { background: var(--crimson); color: var(--white); font-family: 'Montserrat', sans-serif; font-size: 13px; font-weight: 700; padding: 15px 32px; border-radius: 5px; white-space: nowrap; letter-spacing: 0.8px; text-decoration: none; display: inline-block; text-transform: uppercase; }

  /* ── FOOTER ── */
